# Auth key for client access (min 8 chars)
AUTH_KEY=your-auth-key-here

# Internal auth between router and proxies (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_AUTH_SECRET=

# Number of proxy workers to deploy (default: 3)
PROXY_COUNT=3

# Custom domain for the router worker (must be a Cloudflare-proxied zone)
ROUTER_DOMAIN=router.example.com
